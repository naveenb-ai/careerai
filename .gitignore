# ============================================
# ROOT .gitignore
# ============================================

# Environment files - NEVER push these
.env
.env.local
.env.production
*.env

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
env/
ENV/
*.egg-info/
dist/
build/
.eggs/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Jupyter
*.ipynb
.ipynb_checkpoints/

# ML model weight files (auto-downloaded by sentence-transformers)
# NOTE: models/ is removed intentionally — app/models/ contains SQLAlchemy models
*.bin
*.safetensors
huggingface_cache/

# Logs
*.log
logs/

# Database
*.db
*.sqlite

# Build outputs
dist/
build/
.next/
out/

# Codex prompts (internal dev files)
codex_*.md
codex_*.txt

# Test files
test.ipynb

# DB backup (large file, not needed in repo)
career_ai_backup.sql